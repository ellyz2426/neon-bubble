<style>
  .ach-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 3;
    padding-bottom: 3;
    padding-left: 4;
    padding-right: 4;
    background-color: rgba(0, 0, 0, 0.9);
    border-color: #ff00ff;
    border-width: 0.15;
    border-radius: 1.5;
    gap: 0.8;
  }
  .ach-title {
    font-size: 3;
    color: #ff00ff;
    font-weight: bold;
  }
  .ach-count {
    font-size: 1.5;
    color: #808080;
  }
  .ach-row {
    display: flex;
    flex-direction: row;
    width: 100%;
    padding-top: 0.3;
    padding-bottom: 0.3;
    gap: 1;
  }
  .ach-check {
    font-size: 1.2;
    color: #444444;
    width: 8%;
  }
  .ach-done {
    color: #00ff80;
  }
  .ach-name {
    font-size: 1.2;
    color: #ff00ff;
    width: 35%;
    font-weight: bold;
  }
  .ach-desc {
    font-size: 1;
    color: #808080;
    width: 57%;
  }
  .back-btn {
    padding-top: 0.8;
    padding-bottom: 0.8;
    padding-left: 3;
    padding-right: 3;
    background-color: rgba(128, 128, 128, 0.15);
    border-color: #888888;
    border-width: 0.08;
    border-radius: 0.6;
    cursor: pointer;
  }
  .back-text { font-size: 1.8; color: #888888; }
</style>
